{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "formatter": {
    "biome check --write --unsafe {file}": "*.ts,*.tsx,*.json"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm build*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(pnpm db:generate*)",
      "Bash(pnpm db:migrate*)",
      "Bash(pnpm db:seed*)",
      "Bash(ls *)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Task"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*credentials*)"
    ]
  },
  "mcp": {
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "cloudflare-bindings": {
      "type": "remote",
      "url": "https://bindings.mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "cloudflare-observability": {
      "type": "remote",
      "url": "https://observability.mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "cloudflare-radar": {
      "type": "remote",
      "url": "https://radar.mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
